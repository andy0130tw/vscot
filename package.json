{
  "name": "vscot",
  "description": "Range mapper for VS Code extensions",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "author": "qbane",
  "scripts": {
    "preinstall": "cp vendor/cmstate/src/{change,rangeset,text}.ts src/cm",
    "build:cmdts": "tsdown --config=tsdown-cmstate.config.ts && cp node_modules/.tmp/cmstate.in.d.mts src/cm/index.d.ts",
    "tsc": "tsc",
    "build": "tsdown"
  },
  "devDependencies": {
    "@codemirror/state": "^6.6.0",
    "@types/vscode": "^1.110.0",
    "tsdown": "^0.21.5",
    "typescript": "^6.0.2"
  }
}
